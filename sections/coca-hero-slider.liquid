{% comment %}
  Coca Hero Slider (Dawn)
  - Per slide: desktop image + mobile image
  - Different aspect ratio per device (container aspect-ratio)
  - Desktop: arrows + swipe + grab-to-drag
{% endcomment %}
{{ 'cc-hero-slider.css' | asset_url | stylesheet_tag }}
<section
  class="cc-hero section-{{ section.id }}"
  data-cc-hero
  data-autoplay="{{ section.settings.autoplay_enable }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed | default: 5 }}"
>
  <div class="cc-hero__viewport">
    <div class="cc-hero__track" id="ccHeroTrack-{{ section.id }}" data-cc-hero-track>
      {% for block in section.blocks %}
        {% assign d_img = block.settings.image_desktop %}
        {% assign m_img = block.settings.image_mobile %}

        {% assign d_ratio = block.settings.desktop_ratio %}
        {% assign m_ratio = block.settings.mobile_ratio %}

        <article class="cc-hero__slide" data-cc-hero-slide {{ block.shopify_attributes }}>
          <a class="cc-hero__link" href="{{ block.settings.link | default: '#' }}" {% if block.settings.link == blank %}role="link" aria-label="Slide"{% endif %}>
            <div
              class="cc-hero__media"
              style="
                --cc-hero-ratio-desktop: {{ d_ratio }};
                --cc-hero-ratio-mobile: {{ m_ratio }};
              "
            >
              {%- if d_img != blank -%}
                <img
                  class="cc-hero__img cc-hero__img--desktop"
                  srcset="
                    {{ d_img | image_url: width: 900 }} 900w,
                    {{ d_img | image_url: width: 1200 }} 1200w,
                    {{ d_img | image_url: width: 1600 }} 1600w,
                    {{ d_img | image_url: width: 2000 }} 2000w,
                    {{ d_img | image_url: width: 2400 }} 2400w
                  "
                  sizes="100vw"
                  src="{{ d_img | image_url: width: 1600 }}"
                  alt="{{ d_img.alt | escape }}"
                  loading="lazy"
                  width="{{ d_img.width }}"
                  height="{{ d_img.height }}"
                >
              {%- endif -%}

              {%- if m_img != blank -%}
                <img
                  class="cc-hero__img cc-hero__img--mobile"
                  srcset="
                    {{ m_img | image_url: width: 480 }} 480w,
                    {{ m_img | image_url: width: 750 }} 750w,
                    {{ m_img | image_url: width: 990 }} 990w
                  "
                  sizes="100vw"
                  src="{{ m_img | image_url: width: 750 }}"
                  alt="{{ m_img.alt | escape }}"
                  loading="lazy"
                  width="{{ m_img.width }}"
                  height="{{ m_img.height }}"
                >
              {%- endif -%}

              {% if block.settings.heading != blank or block.settings.subheading != blank or block.settings.button_label != blank %}
                <div class="cc-hero__overlay">
                  <div class="cc-hero__text cc-hero__text--desktop cc-hero__text--{{ block.settings.text_align_desktop }}">
                    {% if block.settings.kicker != blank %}
                      <div class="cc-hero__kicker">{{ block.settings.kicker }}</div>
                    {% endif %}
                    {% if block.settings.subheading != blank %}
                      <div class="cc-hero__subheading">{{ block.settings.subheading }}</div>
                    {% endif %}
                    {% if block.settings.heading != blank %}
                      <h2 class="cc-hero__heading">{{ block.settings.heading }}</h2>
                    {% endif %}
                    {% if block.settings.note != blank %}
                      <div class="cc-hero__note">{{ block.settings.note }}</div>
                    {% endif %}
                    {% if block.settings.button_label != blank %}
                      <div class="cc-hero__cta">
                        <span class="cc-hero__btn">
                          {{ block.settings.button_label }}
                        </span>
                      </div>
                    {% endif %}
                  </div>

                  <div class="cc-hero__text cc-hero__text--mobile cc-hero__text--{{ block.settings.text_align_mobile }}">
                    {% if block.settings.kicker != blank %}
                      <div class="cc-hero__kicker">{{ block.settings.kicker }}</div>
                    {% endif %}
                    {% if block.settings.subheading != blank %}
                      <div class="cc-hero__subheading">{{ block.settings.subheading }}</div>
                    {% endif %}
                    {% if block.settings.heading != blank %}
                      <h2 class="cc-hero__heading">{{ block.settings.heading }}</h2>
                    {% endif %}
                    {% if block.settings.note != blank %}
                      <div class="cc-hero__note">{{ block.settings.note }}</div>
                    {% endif %}
                    {% if block.settings.button_label != blank %}
                      <div class="cc-hero__cta">
                        <span class="cc-hero__btn">
                          {{ block.settings.button_label }}
                        </span>
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            </div>
          </a>
        </article>
      {% endfor %}
    </div>

    {% if section.blocks.size > 1 %}
      <button class="cc-hero__nav cc-hero__nav--prev" type="button" aria-label="Previous" data-cc-hero-prev>
        <span aria-hidden="true">‹</span>
      </button>
      <button class="cc-hero__nav cc-hero__nav--next" type="button" aria-label="Next" data-cc-hero-next>
        <span aria-hidden="true">›</span>
      </button>
    {% endif %}

    {% if section.settings.show_dots and section.blocks.size > 1 %}
      <div class="cc-hero__dots" data-cc-hero-dots>
        {% for block in section.blocks %}
          <button class="cc-hero__dot{% if forloop.first %} is-active{% endif %}" type="button" aria-label="Go to slide {{ forloop.index }}" data-cc-hero-dot="{{ forloop.index0 }}"></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>



<script>
  (() => {
    const root = document.querySelector('.section-{{ section.id }}[data-cc-hero]');
    if (!root) return;

    const track = root.querySelector('[data-cc-hero-track]');
    if (!track) return;

    const slides = Array.from(root.querySelectorAll('[data-cc-hero-slide]'));
    const btnPrev = root.querySelector('[data-cc-hero-prev]');
    const btnNext = root.querySelector('[data-cc-hero-next]');
    const dotsWrap = root.querySelector('[data-cc-hero-dots]');
    const dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll('[data-cc-hero-dot]')) : [];
    const autoplayEnabled = root.getAttribute('data-autoplay') === 'true';
    const autoplaySec = Number(root.getAttribute('data-autoplay-speed') || 5);
    const autoplayMs = Math.max(1, autoplaySec) * 1000;
    let autoplayTimer = null;

    const getSlideWidth = () => track.getBoundingClientRect().width;

    const setActiveDot = (index) => {
      if (!dots.length) return;
      dots.forEach(d => d.classList.remove('is-active'));
      if (dots[index]) dots[index].classList.add('is-active');
    };

    const scrollToIndex = (index, smooth = true) => {
      const w = getSlideWidth();
      track.scrollTo({ left: w * index, behavior: smooth ? 'smooth' : 'auto' });
      setActiveDot(index);
    };

    const getCurrentIndex = () => {
      const w = getSlideWidth();
      if (!w) return 0;
      return Math.round(track.scrollLeft / w);
    };

    const goToNext = () => {
      const i = getCurrentIndex();
      const next = i >= slides.length - 1 ? 0 : i + 1;
      scrollToIndex(next);
    };

    const stopAutoplay = () => {
      if (!autoplayTimer) return;
      clearInterval(autoplayTimer);
      autoplayTimer = null;
    };

    const startAutoplay = () => {
      if (!autoplayEnabled || slides.length < 2) return;
      stopAutoplay();
      autoplayTimer = setInterval(goToNext, autoplayMs);
    };

    // arrows
    btnPrev && btnPrev.addEventListener('click', () => {
      const i = getCurrentIndex();
      scrollToIndex(Math.max(0, i - 1));
      startAutoplay();
    });
    btnNext && btnNext.addEventListener('click', () => {
      const i = getCurrentIndex();
      const next = i >= slides.length - 1 ? 0 : i + 1;
      scrollToIndex(next);
      startAutoplay();
    });

    // dots
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const i = Number(dot.getAttribute('data-cc-hero-dot'));
        scrollToIndex(i);
        startAutoplay();
      });
    });

    // grab-to-drag
    let isDown = false;
    let startX = 0;
    let startScrollLeft = 0;
    let moved = 0;

    const onDown = (e) => {
      isDown = true;
      moved = 0;
      stopAutoplay();
      track.classList.add('is-dragging');
      startX = (e.pageX || (e.touches && e.touches[0].pageX) || 0);
      startScrollLeft = track.scrollLeft;
    };

    const onMove = (e) => {
      if (!isDown) return;
      const x = (e.pageX || (e.touches && e.touches[0].pageX) || 0);
      const walk = x - startX;
      moved = Math.max(moved, Math.abs(walk));
      track.scrollLeft = startScrollLeft - walk;
      e.preventDefault();
    };

    const onUp = () => {
      if (!isDown) return;
      isDown = false;
      track.classList.remove('is-dragging');

      // snap to nearest slide
      const i = getCurrentIndex();
      scrollToIndex(i);
      startAutoplay();
    };

    // prevent click if dragged
    track.addEventListener('click', (e) => {
      if (moved > 6) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);

    track.addEventListener('mousedown', onDown);
    window.addEventListener('mousemove', onMove, { passive: false });
    window.addEventListener('mouseup', onUp);

    track.addEventListener('touchstart', onDown, { passive: true });
    track.addEventListener('touchmove', onMove, { passive: false });
    track.addEventListener('touchend', onUp);

    // update dot on scroll end-ish
    let t;
    track.addEventListener('scroll', () => {
      clearTimeout(t);
      t = setTimeout(() => setActiveDot(getCurrentIndex()), 80);
    });

    // init
    setActiveDot(0);
    startAutoplay();

    root.addEventListener('mouseenter', stopAutoplay);
    root.addEventListener('mouseleave', startAutoplay);
  })();
</script>

{% schema %}
{
  "name": "Coca Hero Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "checkbox", "id": "show_dots", "label": "Show dots", "default": true },
    { "type": "checkbox", "id": "autoplay_enable", "label": "Enable autoplay", "default": true },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed (seconds)",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image_desktop", "label": "Desktop image" },
        { "type": "image_picker", "id": "image_mobile", "label": "Mobile image" },

        {
          "type": "select",
          "id": "desktop_ratio",
          "label": "Desktop aspect ratio",
          "options": [
            { "value": "16/6", "label": "Wide (16:6)" },
            { "value": "16/7", "label": "16:7" },
            { "value": "16/8", "label": "16:8" },
            { "value": "21/9", "label": "Cinema (21:9)" },
            { "value": "3/1", "label": "3:1" }
          ],
          "default": "16/6"
        },
        {
          "type": "select",
          "id": "mobile_ratio",
          "label": "Mobile aspect ratio",
          "options": [
            { "value": "3/4", "label": "Portrait (3:4)" },
            { "value": "4/5", "label": "4:5" },
            { "value": "1/1", "label": "Square (1:1)" },
            { "value": "9/16", "label": "Tall (9:16)" }
          ],
          "default": "3/4"
        },

        { "type": "text", "id": "kicker", "label": "Top label (optional)", "default": "Fit by height" },
        { "type": "text", "id": "subheading", "label": "Second label (optional)", "default": "Choose your inseam length" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Ultra Stretch\nSkinny Pants" },
        { "type": "text", "id": "note", "label": "Small note", "default": "MADE FOR EVERY MOMENT" },

        {
          "type": "select",
          "id": "text_align_desktop",
          "label": "Desktop text position",
          "options": [
            { "value": "left", "label": "Top left" },
            { "value": "left-center", "label": "Center left" },
            { "value": "bottom-left", "label": "Bottom left" }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "text_align_mobile",
          "label": "Mobile text position",
          "options": [
            { "value": "left", "label": "Top left" },
            { "value": "left-center", "label": "Center left" },
            { "value": "bottom-left", "label": "Bottom left" }
          ],
          "default": "bottom-left"
        },

        { "type": "text", "id": "button_label", "label": "Button label (optional)" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    { "name": "Coca Hero Slider", "blocks": [{ "type": "slide" }, { "type": "slide" }] }
  ]
}
{% endschema %}

