{{ 'cc-blog-grid.css' | asset_url | stylesheet_tag }}

{% comment %}
  coca-like Blog Grid (Mixed Content) - Dawn compatible
  - Desktop: 6 columns in one row
  - Mobile: 2 columns
  - Data source: Blocks (Article or Collection)
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="cc-blog-grid color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" data-cc-blog-grid>
  <div class="page-width">
    {% if section.settings.show_heading and section.settings.heading != blank %}
      <h2 class="cc-blog-grid__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="cc-blog-grid__grid">
        {% for block in section.blocks %}
          {% liquid
            assign image = blank
            assign title = blank
            assign subtitle = blank
            assign url = blank

            if block.type == 'article'
              assign article = block.settings.article
              if article != blank
                assign image = article.image
                assign title = article.title
                assign url = article.url
                assign subtitle = article.excerpt | strip_html | strip
                if subtitle == blank
                  assign subtitle = article.content | strip_html | strip
                endif
              else
                assign title = 'Example Article'
                assign subtitle = 'Example article content description.'
              endif
            elsif block.type == 'collection'
              assign collection = block.settings.collection
              if collection != blank
                assign image = collection.featured_image
                assign title = collection.title
                assign url = collection.url
                assign subtitle = collection.description | strip_html | strip
              else
                assign title = 'Example Collection'
                assign subtitle = 'Example collection description.'
              endif
            endif
            
            if block.settings.custom_image != blank
              assign image = block.settings.custom_image
            endif
            if block.settings.custom_title != blank
              assign title = block.settings.custom_title
            endif
            if block.settings.custom_description != blank
              assign subtitle = block.settings.custom_description
            endif
          %}

          <article class="cc-blog-grid__card" {{ block.shopify_attributes }}>
            <a class="cc-blog-grid__link" href="{{ url | default: '#' }}">
              <div class="cc-blog-grid__media">
                {% if image %}
                  {{
                    image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'lazy',
                      class: 'cc-blog-grid__img',
                      alt: image.alt | default: title,
                      widths: '360,480,640,750,900,1100',
                      sizes: '(min-width: 990px) 160px, (min-width: 750px) 14vw, 45vw'
                  }}
                {% else %}
                  <div class="cc-blog-grid__img cc-blog-grid__img--placeholder" aria-hidden="true"></div>
                {% endif %}
              </div>

              <div class="cc-blog-grid__text">
                <div class="cc-blog-grid__title">{{ title }}</div>

                {% if section.settings.show_subtitle %}
                  {% if subtitle != blank %}
                    <div class="cc-blog-grid__subtitle">{{ subtitle | truncate: section.settings.subtitle_truncate }}</div>
                  {% else %}
                    <div class="cc-blog-grid__subtitle">&nbsp;</div>
                  {% endif %}
                {% endif %}
              </div>
            </a>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="cc-blog-grid__empty">
        请在区块设置里添加内容（文章或商品系列）
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Coca blog grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FEATURE"
    },
    {
      "type": "checkbox",
      "id": "show_subtitle",
      "label": "Show subtitle (excerpt/content)",
      "default": true
    },
    {
      "type": "range",
      "id": "subtitle_truncate",
      "label": "Subtitle length",
      "min": 30,
      "max": 120,
      "step": 5,
      "default": 60
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Select article"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (Optional)"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title (Optional)"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom Description (Optional)"
        }
      ]
    },
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (Optional)"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title (Optional)"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom Description (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coca blog grid",
      "blocks": [
        { "type": "article" },
        { "type": "article" },
        { "type": "article" },
        { "type": "article" },
        { "type": "article" },
        { "type": "article" }
      ]
    }
  ]
}
{% endschema %}
