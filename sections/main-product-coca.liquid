{{ 'product-coca.css' | asset_url | stylesheet_tag }}

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'coca-utils.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign color_names = section.settings.color_option_names | default: 'Color,Colour' | split: ','
  assign label_add_to_cart = section.settings.add_to_cart_label | default: 'Add to cart'
  assign label_product_code = section.settings.product_code_label | default: 'Product code'
  assign label_desc = section.settings.details_title | default: 'Product details'
  assign label_size_specs = section.settings.size_specs_title | default: 'Size & specifications'
  assign label_size_empty = section.settings.size_info_empty_text | default: 'Size information is being prepared.'
  assign label_material_section = section.settings.material_section_title | default: 'Material info'
  assign label_material = section.settings.material_label | default: 'Material'
  assign label_thickness = section.settings.thickness_label | default: 'Thickness'
  assign label_elasticity = section.settings.elasticity_label | default: 'Elasticity'
  assign label_shipping_return = section.settings.shipping_returns_title | default: 'Shipping & returns'
  assign shipping_returns_content = section.settings.shipping_returns_content | default: 'Shipping: Orders are shipped within 3-5 business days. Free shipping on orders over 11,000 JPY. Returns: Returns/exchanges are accepted within 7 days after delivery for unused items with tags.'
  assign label_shipping_info = section.settings.shipping_info_title | default: 'Delivery information'
  assign shipping_info_content = section.settings.shipping_info_content | default: 'Ships within 3-5 business days after order confirmation. Free shipping on orders over 11,000 JPY.'
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .coca-product__review-badge {
    margin: 8px 0 20px;
  }

  .coca-product__reviews {
    margin-top: 24px;
  }

  .coca-product__app-blocks {
    margin-top: 24px;
  }
{%- endstyle -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign size_pic_raw = product.metafields.custom.size_pic.value | default: product.metafields.custom.size_pic -%}
{%- assign size_pic_list = size_pic_raw | default: '' | replace: '，', ',' | split: ',' -%}
{%- assign material_text = product.metafields.custom.material.value | default: product.metafields.custom.material -%}
{%- assign thickness_text = product.metafields.custom.thickness.value | default: product.metafields.custom.thickness -%}
{%- assign elasticity_text = product.metafields.custom.elasticity.value | default: product.metafields.custom.elasticity -%}

<!-- Breadcrumbs -->
{%- render 'coca-breadcrumbs' -%}

<div class="section-{{ section.id }}-padding">
  <div class="coca-product">
    <div class="coca-product__spu-top">
      <span class="coca-product__spu-label">SPU:</span>
      <span class="coca-product__spu-value">{{ product.id }}</span>
    </div>

    <div class="coca-product__layout">
      <!-- Product Gallery -->
      <div class="coca-product__gallery">
        <!-- Product images JSON -->
        <script id="coca-images-data" type="application/json">
          [
            {%- for image in product.images -%}
              {
                "src": "{{ image | image_url: width: 800 }}",
                "thumb": "{{ image | image_url: width: 150 }}",
                "id": "{{ image.id }}",
                "alt": "{{ image.alt | escape }}"
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        </script>

        <!-- Main image and arrows -->
        <div class="coca-product__main-image">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 800 }}"
                 alt="{{ product.featured_image.alt | escape }}"
                 id="coca-main-image"
                 width="600"
                 height="800">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'coca-product__image-placeholder' }}
          {%- endif -%}

          {%- unless product.available -%}
            <span class="coca-product__badge">SOLD OUT</span>
          {%- endunless -%}
          {%- if product.tags contains 'new' -%}
            <span class="coca-product__badge coca-product__badge--new">NEW</span>
          {%- endif -%}
          {%- if product.tags contains 'kids' or product.tags contains 'KIDS' -%}
            <span class="coca-product__badge coca-product__badge--kids">KIDS</span>
          {%- endif -%}

          {%- if product.images.size > 1 -%}
            <button type="button" class="coca-product__arrow coca-product__arrow--prev" onclick="galleryPrev()" aria-label="Previous image">
              {%- render 'coca-icon', icon: 'arrow-left' -%}
            </button>
            <button type="button" class="coca-product__arrow coca-product__arrow--next" onclick="galleryNext()" aria-label="Next image">
              {%- render 'coca-icon', icon: 'arrow-right' -%}
            </button>
          {%- endif -%}
        </div>

        <!-- Horizontal thumbnail carousel -->
        {%- if product.images.size > 1 -%}
          <div class="coca-product__thumbnail-wrap">
            <div class="coca-product__thumbnail-list" id="coca-thumbnail-list">
              {%- for image in product.images -%}
                <div class="coca-product__thumbnail {% if forloop.first %}active{% endif %}"
                     data-image-src="{{ image | image_url: width: 800 }}"
                     data-image-id="{{ image.id }}"
                     data-index="{{ forloop.index0 }}"
                     onclick="galleryGoTo({{ forloop.index0 }})">
                  <img src="{{ image | image_url: width: 150 }}"
                       alt="{{ image.alt | escape }}"
                       width="70"
                       height="90">
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      <!-- Product Info -->
      <div class="coca-product__info">
        <!-- Brand -->
        {%- if section.settings.show_vendor and product.vendor != blank -%}
          <span class="coca-product__brand">{{ product.vendor | upcase }}</span>
        {%- endif -%}

        <!-- Title -->
        <h1 class="coca-product__title">{{ product.title | escape }}</h1>

        <!-- Price -->
        <div class="coca-product__price">
          &yen;{{ current_variant.price | money_without_currency | replace: ',', '' }}
        </div>

        <!-- Judge.me Preview Badge -->
        <div class="coca-product__review-badge">
          {% render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', concierge_install: true, product: product %}
        </div>

        <!-- Product Form -->
        {%- form 'product', product, id: 'coca-product-form', class: 'coca-product__form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <input
                type="hidden"
                id="coca-option-{{ forloop.index }}"
                name="option{{ forloop.index }}"
                value="{{ option.selected_value | escape }}"
              >
            {%- endfor -%}
          {%- endunless -%}

          <!-- Variant Selectors -->
          <div class="coca-product__variants">
            {%- unless product.has_only_default_variant -%}
              {%- for option in product.options_with_values -%}
                <div class="coca-product__variant-group">
                  <label class="coca-product__variant-label">
                    {{ option.name }}:
                    <span id="selected-option-{{ option.position }}">{{ option.selected_value }}</span>
                  </label>
                  
                  {%- if color_names contains option.name -%}
                    <!-- Color Swatches with Variant Images -->
                    <div class="coca-product__color-options">
                      {%- for value in option.values -%}
                        {%- assign variant_for_value = product.variants | where: 'option1', value | first -%}
                        {%- if variant_for_value == blank -%}
                          {%- assign variant_for_value = product.variants | where: 'option2', value | first -%}
                        {%- endif -%}
                        {%- if variant_for_value == blank -%}
                          {%- assign variant_for_value = product.variants | where: 'option3', value | first -%}
                        {%- endif -%}
                        {%- assign variant_image = variant_for_value.image -%}
                        <button type="button" 
                                class="coca-product__color-swatch {% if option.selected_value == value %}active{% endif %}"
                                onclick="selectOption({{ option.position }}, '{{ value | escape }}', this)"
                                title="{{ value | escape }}"
                                {%- if variant_image != blank -%}
                                  data-image-src="{{ variant_image | image_url: width: 800 }}"
                                  data-image-id="{{ variant_image.id }}"
                                {%- endif -%}>
                          {%- if variant_image != blank -%}
                            <img src="{{ variant_image | image_url: width: 120 }}"
                                 alt="{{ value | escape }}"
                                 width="60"
                                 height="60"
                                 loading="lazy">
                          {%- else -%}
                            <span class="coca-product__color-swatch-fallback" style="background-color: {{ value | downcase | replace: ' ', '' }};">{{ value | slice: 0 }}</span>
                          {%- endif -%}
                        </button>
                      {%- endfor -%}
                    </div>
                  {%- else -%}
                    <!-- Size/Other Options -->
                    <div class="coca-product__size-options">
                      {%- for value in option.values -%}
                        {%- assign value_available = false -%}
                        {%- case option.position -%}
                          {%- when 1 -%}
                            {%- for variant in product.variants -%}
                              {%- if variant.option1 == value and variant.available -%}
                                {%- assign value_available = true -%}
                                {%- break -%}
                              {%- endif -%}
                            {%- endfor -%}
                          {%- when 2 -%}
                            {%- for variant in product.variants -%}
                              {%- if variant.option2 == value and variant.available -%}
                                {%- assign value_available = true -%}
                                {%- break -%}
                              {%- endif -%}
                            {%- endfor -%}
                          {%- when 3 -%}
                            {%- for variant in product.variants -%}
                              {%- if variant.option3 == value and variant.available -%}
                                {%- assign value_available = true -%}
                                {%- break -%}
                              {%- endif -%}
                            {%- endfor -%}
                        {%- endcase -%}
                        <button type="button" 
                                class="coca-product__size-btn {% if option.selected_value == value %}active{% endif %}"
                                onclick="selectOption({{ option.position }}, '{{ value | escape }}', this)"
                                {% unless value_available %}disabled{% endunless %}>
                          {{ value }}
                        </button>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            {%- endunless -%}
          </div>

          <!-- Quantity & Add to Cart -->
          <div class="coca-product__actions">
            <div class="coca-product__quantity">
              <button type="button" class="coca-product__quantity-btn" onclick="updateQuantity(-1)">-</button>
              <input type="number" name="quantity" value="1" min="1" class="coca-product__quantity-input" id="coca-quantity">
              <button type="button" class="coca-product__quantity-btn" onclick="updateQuantity(1)">+</button>
            </div>
            
            <button type="submit" 
                    class="coca-product__add-cart"
                    {% unless current_variant.available %}disabled{% endunless %}>
              {%- if current_variant.available -%}
                {{ label_add_to_cart }}
              {%- else -%}
                SOLD OUT
              {%- endif -%}
            </button>
            
            <button type="button" class="coca-product__wishlist" onclick="toggleWishlist(this)">
              {%- render 'coca-icon', icon: 'heart' -%}
            </button>
          </div>
        {%- endform -%}

        <!-- Product Meta -->
        <div class="coca-product__meta">
          {{ label_product_code }}: {{ current_variant.sku | default: product.id }}
        </div>

        <!-- Accordion Sections -->
        <div class="coca-product__accordion">
          <!-- Product Description -->
          <div class="coca-product__accordion-item active">
            <div class="coca-product__accordion-header" onclick="cocaToggleAccordion(this, { exclusive: false })">
              <span>{{ label_desc }}</span>
              <span class="coca-product__accordion-toggle">{%- render 'coca-icon', icon: 'chevron-down' -%}</span>
            </div>
            <div class="coca-product__accordion-content">
              <div class="coca-product__accordion-body">
                {{ product.description }}
              </div>
            </div>
          </div>

          <!-- Size Guide -->
          <div class="coca-product__accordion-item active" id="size-guide">
            <div class="coca-product__accordion-header" onclick="cocaToggleAccordion(this, { exclusive: false })">
              <span>{{ label_size_specs }}</span>
              <span class="coca-product__accordion-toggle">{%- render 'coca-icon', icon: 'chevron-down' -%}</span>
            </div>
            <div class="coca-product__accordion-content">
              <div class="coca-product__accordion-body">
                {%- assign has_size_pic = false -%}
                {%- for raw_url in size_pic_list -%}
                  {%- assign url = raw_url | strip -%}
                  {%- if url != blank -%}
                    {%- assign has_size_pic = true -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- if has_size_pic -%}
                  <div class="coca-product__size-pics">
                    {%- for raw_url in size_pic_list -%}
                      {%- assign url = raw_url | strip -%}
                      {%- if url != blank -%}
                        {%- liquid
                          assign size_pic_src = url
                          if url contains '://'
                            assign size_pic_src = url
                          elsif url contains '/cdn/shop/files/'
                            assign size_pic_src = url
                          else
                            assign normalized_file = url | remove_first: '/'
                            assign size_pic_src = '/cdn/shop/files/' | append: normalized_file
                          endif
                        -%}
                        <img
                          src="{{ size_pic_src | escape }}"
                          alt="{{ product.title | escape }} size chart {{ forloop.index }}"
                          class="coca-product__size-pic"
                          loading="lazy"
                          width="1200"
                          height="1200"
                        >
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- elsif product.metafields.custom.size_guide != blank -%}
                  {{ product.metafields.custom.size_guide }}
                {%- else -%}
                  <p>{{ label_size_empty }}</p>
                {%- endif -%}
              </div>
            </div>
          </div>

          <!-- Material / Thickness / Elasticity -->
          <div class="coca-product__accordion-item active">
            <div class="coca-product__accordion-header" onclick="cocaToggleAccordion(this, { exclusive: false })">
              <span>{{ label_material_section }}</span>
              <span class="coca-product__accordion-toggle">{%- render 'coca-icon', icon: 'chevron-down' -%}</span>
            </div>
            <div class="coca-product__accordion-content">
              <div class="coca-product__accordion-body">
                <dl class="coca-product__spec-list">
                  <div class="coca-product__spec-row">
                    <dt>{{ label_material }}</dt>
                    <dd>{{ material_text | default: '' }}</dd>
                  </div>
                  <div class="coca-product__spec-row">
                    <dt>{{ label_thickness }}</dt>
                    <dd>{{ thickness_text | default: '' }}</dd>
                  </div>
                  <div class="coca-product__spec-row">
                    <dt>{{ label_elasticity }}</dt>
                    <dd>{{ elasticity_text | default: '' }}</dd>
                  </div>
                </dl>
              </div>
            </div>
          </div>

          <!-- Shipping -->
          <div class="coca-product__accordion-item active">
            <div class="coca-product__accordion-header" onclick="cocaToggleAccordion(this, { exclusive: false })">
              <span>{{ label_shipping_return }}</span>
              <span class="coca-product__accordion-toggle">{%- render 'coca-icon', icon: 'chevron-down' -%}</span>
            </div>
            <div class="coca-product__accordion-content">
              <div class="coca-product__accordion-body">
                {{ shipping_returns_content | escape | newline_to_br }}
              </div>
            </div>
          </div>

          {%- if section.settings.show_notice and section.settings.notice_content != blank -%}
            <div class="coca-product__accordion-item active">
              <div class="coca-product__accordion-header" onclick="cocaToggleAccordion(this, { exclusive: false })">
                <span>{{ section.settings.notice_title | default: 'Notes' }}</span>
                <span class="coca-product__accordion-toggle">{%- render 'coca-icon', icon: 'chevron-down' -%}</span>
              </div>
              <div class="coca-product__accordion-content">
                <div class="coca-product__accordion-body">
                  {{ section.settings.notice_content | escape | newline_to_br }}
                </div>
              </div>
            </div>
          {%- endif -%}
        </div>

        <!-- Shipping Info -->
        <div class="coca-product__shipping">
          <div class="coca-product__shipping-title">{{ label_shipping_info }}</div>
          <p>{{ shipping_info_content | escape | newline_to_br }}</p>
        </div>

        <!-- Share -->
        <div class="coca-product__share">
          {%- render 'coca-share-buttons',
            share_url: product.url,
            share_title: product.title,
            show_label: false,
            button_class: 'coca-product__share-btn'
          -%}
        </div>

        <!-- Judge.me Full Review Widget -->
        <div class="coca-product__reviews">
          {% render 'judgeme_widgets', widget_type: 'judgeme_review_widget', concierge_install: true, product: product %}
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="coca-product__app-blocks">
            {%- for block in section.blocks -%}
              {%- if block.type == '@app' -%}
                <div {{ block.shopify_attributes }}>
                  {% render block %}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<!-- Notification -->
<div id="coca-notification" class="coca-product__notification">
  Added to cart
</div>

<script>
  // ========== Gallery Controller ==========
  const cocaImages = JSON.parse(document.getElementById('coca-images-data').textContent);
  let cocaCurrentIndex = 0;

  function galleryGoTo(index) {
    if (!cocaImages.length) return;
    cocaCurrentIndex = (index + cocaImages.length) % cocaImages.length;
    const img = cocaImages[cocaCurrentIndex];

    // Update main image
    const mainImg = document.getElementById('coca-main-image');
    if (mainImg) mainImg.src = img.src;

    // Update active thumbnail and keep it in view
    const thumbnails = document.querySelectorAll('.coca-product__thumbnail');
    thumbnails.forEach(t => t.classList.remove('active'));
    if (thumbnails[cocaCurrentIndex]) {
      thumbnails[cocaCurrentIndex].classList.add('active');
      thumbnails[cocaCurrentIndex].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    }
  }

  function galleryPrev() { galleryGoTo(cocaCurrentIndex - 1); }
  function galleryNext() { galleryGoTo(cocaCurrentIndex + 1); }

  // ========== Quantity ==========
  function updateQuantity(change) {
    const input = document.getElementById('coca-quantity');
    let value = parseInt(input.value) + change;
    if (value < 1) value = 1;
    input.value = value;
  }

  // ========== Select Option ==========
  function selectOption(optionPosition, value, element) {
    const group = element.closest('.coca-product__variant-group');
    group.querySelectorAll('.coca-product__color-swatch, .coca-product__size-btn').forEach(el => {
      el.classList.remove('active');
    });
    element.classList.add('active');

    const hiddenInput = document.getElementById('coca-option-' + optionPosition);
    if (hiddenInput) hiddenInput.value = value;

    const selectedLabel = document.getElementById('selected-option-' + optionPosition);
    if (selectedLabel) selectedLabel.textContent = value;

    // Sync main image when selecting a color swatch
    const imageId = element.dataset.imageId;
    if (imageId) {
      const idx = cocaImages.findIndex(img => img.id === imageId);
      if (idx !== -1) galleryGoTo(idx);
    }

    updateVariant();
  }

  // ========== Update Variant ==========
  function updateVariant() {
    const form = document.getElementById('coca-product-form');
    const formData = new FormData(form);
    const variants = {{ product.variants | json }};
    let selectedVariant = variants[0];

    for (const variant of variants) {
      let match = true;
      {% for option in product.options %}
        const option{{ forloop.index }} = formData.get('option{{ forloop.index }}') || document.querySelector('[name="option{{ forloop.index }}"]')?.value || variant.option{{ forloop.index }};
        if (variant.option{{ forloop.index }} !== option{{ forloop.index }}) match = false;
      {% endfor %}
      if (match) { selectedVariant = variant; break; }
    }

    form.querySelector('input[name="id"]').value = selectedVariant.id;
    document.querySelector('.coca-product__price').innerHTML = '&yen;' + (selectedVariant.price / 100).toLocaleString();

    const addButton = form.querySelector('.coca-product__add-cart');
    if (selectedVariant.available) {
      addButton.disabled = false;
      addButton.textContent = {{ label_add_to_cart | json }};
    } else {
      addButton.disabled = true;
      addButton.textContent = 'SOLD OUT';
    }
    document.querySelector('.coca-product__meta').textContent = {{ label_product_code | json }} + ': ' + (selectedVariant.sku || selectedVariant.id);
  }

  // ========== Wishlist ==========
  function toggleWishlist(button) {
    button.classList.toggle('coca-product__wishlist--active');
    cocaShowNotification(button.classList.contains('coca-product__wishlist--active') ? 'Added to wishlist' : 'Removed from wishlist');
  }

  // ========== Add to Cart ==========
  document.getElementById('coca-product-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const cartDrawer = document.querySelector('cart-drawer');

    if (cartDrawer && typeof cartDrawer.getSectionsToRender === 'function') {
      formData.append(
        'sections',
        cartDrawer.getSectionsToRender().map((section) => section.id)
      );
      formData.append('sections_url', window.location.pathname);
    }

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      body: formData
    })
      .then(r => r.json())
      .then((response) => {
        if (response.status) {
          return;
        }

        if (cartDrawer && typeof cartDrawer.renderContents === 'function') {
          cartDrawer.renderContents(response);
          if (window.innerWidth < 990) {
            cartDrawer.open(document.querySelector('.coca-icon-btn--cart') || document.activeElement);
          }
        }

        cocaRefreshCartCount();
      })
      .catch((error) => {
        console.error('Add to cart failed:', error);
      });
  });

  updateVariant();
</script>

{% schema %}
{
  "name": "Coca Product",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Product Information"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "default": true,
      "label": "Show SKU"
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "default": true,
      "label": "Show share buttons"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium",
      "label": "Media size"
    },
    {
      "type": "header",
      "content": "Variant Options"
    },
    {
      "type": "text",
      "id": "color_option_names",
      "label": "Color option names",
      "default": "Color,Colour",
      "info": "Separate by commas. Matching option names are treated as color selectors."
    },
    {
      "type": "header",
      "content": "Notice"
    },
    {
      "type": "checkbox",
      "id": "show_notice",
      "default": true,
      "label": "Show notice"
    },
    {
      "type": "text",
      "id": "notice_title",
      "label": "Notice title",
