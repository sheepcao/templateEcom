{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% liquid
  assign related_collection = article.metafields.custom.related_collection.value
  
  assign products_to_display = blank
  if related_collection != blank
    assign products_to_display = related_collection.products
  elsif section.settings.collection != blank
    assign products_to_display = section.settings.collection.products
  endif
%}

{% if section.settings.show_collection %}
  {% if products_to_display != blank or request.design_mode %}
    <div class="page-width" style="margin-top: 60px;">
      {% if section.settings.heading != blank %}
        <h2 style="text-align:center;margin-bottom:40px;">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if products_to_display != blank %}
        <ul class="grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop">
          {% for product in products_to_display %}
            <li class="grid__item">
              {% render 'card-product-coca',
                card_product: product,
                media_aspect_ratio: 'square',
                show_secondary_image: true,
                show_vendor: false,
                show_rating: false,
                show_quick_add: true
              %}
            </li>
          {% endfor %}
        </ul>
      {% elsif request.design_mode %}
        <div class="rte" style="text-align:center;opacity:.7;">
          <p>Please select a default collection in Theme Editor, or set <code>custom.related_collection</code> on the article.</p>
        </div>
      {% endif %}
    </div>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Article with Collection",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_collection",
      "label": "Show collection below article",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Collection heading",
      "default": "Related Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4",
      "label": "Desktop columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2",
      "label": "Mobile columns"
    }
  ],
  "presets": [
    {
      "name": "Article with Collection"
    }
  ]
}
{% endschema %}
