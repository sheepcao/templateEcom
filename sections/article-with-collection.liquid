{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'card-product-coca.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .article-related-{{ section.id }} {
    margin-top: 60px;
  }

  .article-related-{{ section.id }}__heading {
    text-align: center;
    margin: 0 0 40px;
  }

  .article-related-{{ section.id }}__grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
  }

  @media screen and (min-width: 990px) {
    .article-related-{{ section.id }}__grid {
      gap: 20px;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

{% liquid
  assign related_collection = article.metafields.custom.related_collection.value
  
  assign products_to_display = blank
  if related_collection != blank
    assign products_to_display = related_collection.products
  endif
%}

{% if section.settings.show_collection and related_collection != blank and products_to_display != blank %}
    <div class="page-width article-related-{{ section.id }}">
      {% if section.settings.heading != blank %}
        <h2 class="article-related-{{ section.id }}__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      <div class="article-related-{{ section.id }}__grid">
        {% for product in products_to_display limit: section.settings.products_to_show %}
          <div class="article-related-{{ section.id }}__item">
            {% render 'card-product-coca',
              card_product: product,
              media_aspect_ratio: 'square',
              show_secondary_image: true,
              show_vendor: false,
              show_rating: false,
              show_quick_add: false,
              show_color_dots: false
            %}
          </div>
        {% endfor %}
      </div>
    </div>
{% endif %}

{% schema %}
{
  "name": "Article with Collection",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_collection",
      "label": "Show collection below article",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Collection heading",
      "default": "Related Products"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4",
      "label": "Desktop columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2",
      "label": "Mobile columns"
    }
  ],
  "presets": [
    {
      "name": "Article with Collection"
    }
  ]
}
{% endschema %}
